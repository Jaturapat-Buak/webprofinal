<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <table>
        <tr>
            <th>ID</th><th>First Name</th><th>Last Name</th><th>Username</th><th>Email</th><th>Actions</th>
        </tr>
        <% data.forEach(item => { %>
            <tr>
                <td><%= item.id %></td>
                <td><%= item.first_name %></td>
                <td><%= item.last_name %></td>
                <td><%= item.username %></td>
                <td><%= item.email %></td>
                <td>
                    <a href = "/detail/<%= item.id %>">Detail</a>
                </td>
            </tr>
        <% }) %>
    </table>
</body>
</html>