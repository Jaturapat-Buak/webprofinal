<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href = "/boots/css/bootstrap.min.css" rel = "stylesheet">
    <script src = "/boots/js/bootstrap.min.js"></script>
    <title>Document</title>
</head>
<body style = "padding: 20px;">
    <h1>To-Do Lists</h1>
    <a href = "/add"><button class = "btn btn-primary">add</button></a>
    <table class = "table table-bordered">
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Description</th>
            <th>Deadline</th>
            <th>State</th>
            <th>Action</th>
        </tr>
        <% data.forEach((item) => { %>
        <tr>
            <td><%= item.id %></td>
            <td><%= item.title %></td>
            <td><%= item.description %></td>
            <td><%= item.deadline %></td>
            <td><%= item.state %>
                <form method="POST" action = "/update/<%= item.id %>">
                    <input type = "checkbox" 
                    name = "state" 
                    value = "yes" 
                    onchange="this.form.submit()" 
                    <%= item.state === 'yes' ? 'checked' : '' %>>
                </form>
            </td>
            <td>
                <form method="POST" action = "/del/<%= item.id %>">
                    <button class = "btn btn-danger">DELETE</button>
                </form>
            </td>
        </tr>
        <% }) %>
    </table>
</body>
</html>